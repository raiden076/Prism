{
	"$schema": "../node_modules/wrangler/config-schema.json",
	"name": "pdf-virus-scanner",
	"main": "src/index.ts",
	"compatibility_date": "2025-03-20",
	"compatibility_flags": ["nodejs_compat"],

	"vars": {
		"MAX_FILE_SIZE_MB": "10"
	},

	"observability": {
		"enabled": true,
		"head_sampling_rate": 1
	}
}
