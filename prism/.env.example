# PRISM Frontend Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# SuperTokens Configuration (Required)
# ============================================
# Get these from your SuperTokens Managed Dashboard
VITE_SUPERTOKENS_CORE_URL=https://your-app.supertokens.io
VITE_SUPERTOKENS_API_KEY=your-supertokens-api-key

# ============================================
# API Configuration
# ============================================
# Backend API URL (prism-engine Cloudflare Worker)
VITE_API_BASE_URL=http://localhost:8787

# ============================================
# Feature Flags
# ============================================
# Enable SuperTokens authentication (gradual rollout)
VITE_USE_SUPERTOKENS_AUTH=false

# ============================================
# Optional: Development Settings
# ============================================
# Enable debug logging for auth flows
VITE_DEBUG_AUTH=false
